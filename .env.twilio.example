# Twilio Configuration Template
# Copy to .env.local or configure in Supabase Secrets

# Twilio Account Credentials
# Get these from https://www.twilio.com/console
VITE_TWILIO_ACCOUNT_SID=your_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_auth_token_here
VITE_TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Note: For Supabase Edge Functions, use Supabase Secrets instead:
# supabase secrets set TWILIO_ACCOUNT_SID "your_account_sid"
# supabase secrets set TWILIO_AUTH_TOKEN "your_auth_token"
# supabase secrets set TWILIO_PHONE_NUMBER "+1XXXXXXXXXX"
